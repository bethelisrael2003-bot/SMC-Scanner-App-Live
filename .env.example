# Capital.com Credentials
CAPITAL_API_KEY=your_capital_api_key
CAPITAL_EMAIL=your_email
CAPITAL_PASSWORD=your_password

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# Environment
NODE_ENV=development
PORT=3000

# Backend URL for Frontend (use your Render URL when deployed)
VITE_API_URL=http://localhost:3000

# MongoDB URI (Atlas Connection String)
MONGODB_URI=your_mongodb_atlas_uri

# Secret for cron trigger
CRON_SECRET=my_secret_token
